{
  "name": "Aurora Polaris Chess",
  "version": "2.1.2",
  "description": "A pure client-side chess game implementation that runs entirely in the browser. All computation happens on the client side, making it perfect for static hosting on GitHub Pages.",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "playwright test",
    "test:quick": "playwright test --grep-invert 'Full Game Tests'",
    "test:full-game": "playwright test --grep 'Full Game Tests'",
    "test:full-game:headed": "playwright test --grep 'Full Game Tests' --headed",
    "test:all": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:unit": "playwright test tests/unit/",
    "test:integration": "playwright test tests/integration/",
    "test:performance": "playwright test tests/performance/",
    "test:accessibility": "playwright test tests/accessibility/",
    "test:security": "playwright test tests/security/",
    "test:ai": "playwright test tests/unit/engine/AI.spec.js",
    "test:coverage": "node tests/coverage/run-coverage.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nostromo-618/aurora-polaris-chess.git"
  },
  "keywords": [
    "chess",
    "browser",
    "vanilla-js",
    "ai",
    "game"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Nostromo-618/aurora-polaris-chess/issues"
  },
  "homepage": "https://github.com/Nostromo-618/aurora-polaris-chess#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "v8-to-istanbul": "^9.3.0"
  }
}
